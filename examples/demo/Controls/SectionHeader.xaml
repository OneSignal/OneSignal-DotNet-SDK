<?xml version="1.0" encoding="utf-8" ?>
<ContentView
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
  x:Class="OneSignalDemo.Controls.SectionHeader"
  x:Name="self"
>
  <Grid ColumnDefinitions="*,Auto" Padding="4,0,0,0">
    <Label
      Grid.Column="0"
      Text="{Binding Title, Source={x:Reference self}}"
      Style="{StaticResource SectionHeaderStyle}"
      VerticalOptions="Center"
    />
    <ImageButton
      Grid.Column="1"
      x:Name="InfoButton"
      Source="{mi:Material Icon=InfoOutline, IconSize=20, IconColor=#9E9E9E}"
      Aspect="Center"
      WidthRequest="32"
      HeightRequest="32"
      Padding="0"
      Margin="0,0,-11,0"
      BackgroundColor="Transparent"
      Clicked="OnInfoTappedInternal"
    />
  </Grid>
</ContentView>
