<?xml version="1.0" encoding="utf-8" ?>
<ContentView
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:controls="clr-namespace:OneSignalDemo.Controls"
  x:Class="OneSignalDemo.Controls.Sections.SendPushSection"
>
  <VerticalStackLayout Spacing="8" AutomationId="send_push_section">
    <controls:SectionHeader
      Title="SEND PUSH NOTIFICATION"
      SectionKey="send_push"
      InfoTapped="OnInfoTapped"
    />

    <Button
      Text="SIMPLE"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnSimpleClicked"
      AutomationId="send_simple_button"
    />
    <Button
      Text="WITH IMAGE"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnWithImageClicked"
      AutomationId="send_image_button"
    />
    <Button
      Text="WITH SOUND"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnWithSoundClicked"
      AutomationId="send_sound_button"
    />
    <Button
      Text="CUSTOM"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnCustomClicked"
      AutomationId="send_custom_button"
    />
    <Button
      Text="CLEAR ALL"
      Style="{StaticResource OutlineButtonStyle}"
      Clicked="OnClearAllClicked"
      AutomationId="clear_all_button"
    />
  </VerticalStackLayout>
</ContentView>
