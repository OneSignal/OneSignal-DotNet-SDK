<?xml version="1.0" encoding="utf-8" ?>
<ContentView
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
  x:Class="OneSignalDemo.Controls.Sections.SendPushSection"
>
  <VerticalStackLayout Spacing="8" AutomationId="send_push_section">
    <Grid ColumnDefinitions="*,Auto" Padding="4,0,0,0">
      <Label
        Grid.Column="0"
        Text="SEND PUSH NOTIFICATION"
        Style="{StaticResource SectionHeaderStyle}"
        VerticalOptions="Center"
      />
      <ImageButton
        Grid.Column="1"
        Source="{mi:Material Icon=InfoOutline, IconSize=18, IconColor=#9E9E9E}"
        WidthRequest="18"
        HeightRequest="18"
        BackgroundColor="Transparent"
        Clicked="OnInfoTapped"
        Padding="0"
        AutomationId="send_push_info_icon"
      />
    </Grid>

    <Button
      Text="SIMPLE"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnSimpleClicked"
      AutomationId="send_simple_button"
    />
    <Button
      Text="WITH IMAGE"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnWithImageClicked"
      AutomationId="send_image_button"
    />
    <Button
      Text="CUSTOM"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnCustomClicked"
      AutomationId="send_custom_button"
    />
    <Button
      Text="CLEAR ALL"
      Style="{StaticResource OutlineButtonStyle}"
      Clicked="OnClearAllClicked"
      AutomationId="clear_all_button"
    />
  </VerticalStackLayout>
</ContentView>
