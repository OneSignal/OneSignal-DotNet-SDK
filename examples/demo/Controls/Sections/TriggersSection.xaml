<?xml version="1.0" encoding="utf-8" ?>
<ContentView
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:controls="clr-namespace:OneSignalDemo.Controls"
  x:Class="OneSignalDemo.Controls.Sections.TriggersSection"
>
  <VerticalStackLayout Spacing="8" AutomationId="triggers_section">
    <controls:SectionHeader Title="TRIGGERS" SectionKey="triggers" InfoTapped="OnInfoTapped" />

    <Border Style="{StaticResource CardBorderStyle}">
      <VerticalStackLayout x:Name="TriggerListContainer" MinimumHeightRequest="50">
        <Label
          x:Name="EmptyLabel"
          Text="No triggers added"
          Style="{StaticResource EmptyStateStyle}"
          Padding="16"
          AutomationId="triggers_empty"
        />
      </VerticalStackLayout>
    </Border>

    <Button
      Text="ADD TRIGGER"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnAddClicked"
      AutomationId="add_trigger_button"
    />
    <Button
      Text="ADD MULTIPLE TRIGGERS"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnAddMultipleClicked"
      AutomationId="add_multiple_triggers_button"
    />
    <Button
      x:Name="RemoveSelectedButton"
      Text="REMOVE TRIGGERS"
      Style="{StaticResource PrimaryButtonStyle}"
      IsVisible="False"
      Clicked="OnRemoveSelectedClicked"
      AutomationId="remove_triggers_button"
    />
    <Button
      x:Name="ClearAllButton"
      Text="CLEAR ALL TRIGGERS"
      Style="{StaticResource PrimaryButtonStyle}"
      IsVisible="False"
      Clicked="OnClearAllClicked"
      AutomationId="clear_triggers_button"
    />
  </VerticalStackLayout>
</ContentView>
