<?xml version="1.0" encoding="utf-8" ?>
<ContentView
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:controls="clr-namespace:OneSignalDemo.Controls"
  x:Class="OneSignalDemo.Controls.Sections.AliasesSection"
>
  <VerticalStackLayout Spacing="8" AutomationId="aliases_section">
    <controls:SectionHeader Title="ALIASES" SectionKey="aliases" InfoTapped="OnInfoTapped" />

    <Border Style="{StaticResource CardBorderStyle}">
      <VerticalStackLayout x:Name="AliasListContainer" MinimumHeightRequest="50">
        <Label
          x:Name="EmptyLabel"
          Text="No aliases added"
          Style="{StaticResource EmptyStateStyle}"
          Padding="16"
          AutomationId="aliases_empty"
        />
      </VerticalStackLayout>
    </Border>

    <Button
      Text="ADD ALIAS"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnAddClicked"
      AutomationId="add_alias_button"
    />
    <Button
      Text="ADD MULTIPLE ALIASES"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnAddMultipleClicked"
      AutomationId="add_multiple_aliases_button"
    />
  </VerticalStackLayout>
</ContentView>
