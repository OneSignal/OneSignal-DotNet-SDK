<?xml version="1.0" encoding="utf-8" ?>
<ContentView
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:controls="clr-namespace:OneSignalDemo.Controls"
  x:Class="OneSignalDemo.Controls.Sections.InAppSection"
>
  <VerticalStackLayout Spacing="8" AutomationId="iam_section">
    <controls:SectionHeader Title="IN-APP MESSAGING" SectionKey="iam" InfoTapped="OnInfoTapped" />

    <Border Style="{StaticResource CardBorderStyle}">
      <Grid Padding="12" ColumnDefinitions="*,Auto">
        <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
          <Label Text="Pause In-App Messages" Style="{StaticResource BodyMediumStyle}" />
          <Label Text="Toggle in-app message display" Style="{StaticResource BodySmallStyle}" />
        </VerticalStackLayout>
        <Switch
          Grid.Column="1"
          x:Name="IamPausedSwitch"
          IsToggled="False"
          Toggled="OnIamPausedToggled"
          AutomationId="pause_iam_toggle"
        />
      </Grid>
    </Border>
  </VerticalStackLayout>
</ContentView>
