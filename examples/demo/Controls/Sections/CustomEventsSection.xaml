<?xml version="1.0" encoding="utf-8" ?>
<ContentView
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:controls="clr-namespace:OneSignalDemo.Controls"
  x:Class="OneSignalDemo.Controls.Sections.CustomEventsSection"
>
  <VerticalStackLayout Spacing="8" AutomationId="custom_events_section">
    <controls:SectionHeader
      Title="CUSTOM EVENTS"
      SectionKey="custom_events"
      InfoTapped="OnInfoTapped"
    />

    <Button
      Text="TRACK EVENT"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnTrackEventClicked"
      AutomationId="track_event_button"
    />
  </VerticalStackLayout>
</ContentView>
