<?xml version="1.0" encoding="utf-8" ?>
<ContentView
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:controls="clr-namespace:OneSignalDemo.Controls"
  x:Class="OneSignalDemo.Controls.Sections.OutcomesSection"
>
  <VerticalStackLayout Spacing="8" AutomationId="outcomes_section">
    <controls:SectionHeader
      Title="OUTCOME EVENTS"
      SectionKey="outcomes"
      InfoTapped="OnInfoTapped"
    />

    <Button
      Text="SEND OUTCOME"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnSendOutcomeClicked"
      AutomationId="send_outcome_button"
    />
  </VerticalStackLayout>
</ContentView>
