<?xml version="1.0" encoding="utf-8" ?>
<ContentView
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:controls="clr-namespace:OneSignalDemo.Controls"
  x:Class="OneSignalDemo.Controls.Sections.SmsSection"
>
  <VerticalStackLayout Spacing="8" AutomationId="sms_section">
    <controls:SectionHeader Title="SMS" SectionKey="sms" InfoTapped="OnInfoTapped" />

    <Border Style="{StaticResource CardBorderStyle}">
      <VerticalStackLayout x:Name="SmsListContainer" MinimumHeightRequest="50">
        <Label
          x:Name="EmptyLabel"
          Text="No SMS added"
          Style="{StaticResource EmptyStateStyle}"
          Padding="16"
          AutomationId="sms_empty"
        />
      </VerticalStackLayout>
    </Border>

    <Button
      Text="ADD SMS"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnAddSmsClicked"
      AutomationId="add_sms_button"
    />
  </VerticalStackLayout>
</ContentView>
