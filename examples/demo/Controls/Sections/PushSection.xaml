<?xml version="1.0" encoding="utf-8" ?>
<ContentView
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:controls="clr-namespace:OneSignalDemo.Controls"
  x:Class="OneSignalDemo.Controls.Sections.PushSection"
  x:Name="root"
>
  <VerticalStackLayout Spacing="8" AutomationId="push_section">
    <controls:SectionHeader Title="PUSH" SectionKey="push" InfoTapped="OnInfoTapped" />

    <Border Style="{StaticResource CardBorderStyle}">
      <VerticalStackLayout>
        <Grid Padding="12" ColumnDefinitions="*,Auto">
          <Label
            Grid.Column="0"
            Text="Push ID"
            Style="{StaticResource BodyMediumStyle}"
            VerticalOptions="Center"
          />
          <Label
            Grid.Column="1"
            x:Name="PushIdLabel"
            Text=""
            Style="{StaticResource BodySmallStyle}"
            FontFamily="DroidSansMono"
            HorizontalOptions="End"
            VerticalOptions="Center"
            LineBreakMode="MiddleTruncation"
            AutomationId="push_id_value"
          />
        </Grid>
        <BoxView HeightRequest="1" Color="{StaticResource OsDivider}" Margin="12,0" />
        <Grid Padding="12" ColumnDefinitions="*,Auto">
          <Label
            Grid.Column="0"
            Text="Enabled"
            Style="{StaticResource BodyMediumStyle}"
            VerticalOptions="Center"
          />
          <Switch
            Grid.Column="1"
            x:Name="PushEnabledSwitch"
            IsToggled="False"
            Toggled="OnPushEnabledToggled"
            AutomationId="push_enabled_toggle"
          />
        </Grid>
      </VerticalStackLayout>
    </Border>

    <Button
      x:Name="PromptPushButton"
      Text="PROMPT PUSH"
      Style="{StaticResource PrimaryButtonStyle}"
      IsVisible="False"
      Clicked="OnPromptPushClicked"
      AutomationId="prompt_push_button"
    />
  </VerticalStackLayout>
</ContentView>
