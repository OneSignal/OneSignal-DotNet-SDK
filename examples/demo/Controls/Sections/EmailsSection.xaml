<?xml version="1.0" encoding="utf-8" ?>
<ContentView
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:controls="clr-namespace:OneSignalDemo.Controls"
  x:Class="OneSignalDemo.Controls.Sections.EmailsSection"
>
  <VerticalStackLayout Spacing="8" AutomationId="emails_section">
    <controls:SectionHeader Title="EMAILS" SectionKey="emails" InfoTapped="OnInfoTapped" />

    <Border Style="{StaticResource CardBorderStyle}">
      <VerticalStackLayout x:Name="EmailListContainer" MinimumHeightRequest="50">
        <Label
          x:Name="EmptyLabel"
          Text="No emails added"
          Style="{StaticResource EmptyStateStyle}"
          Padding="16"
          AutomationId="emails_empty"
        />
      </VerticalStackLayout>
    </Border>

    <Button
      Text="ADD EMAIL"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnAddEmailClicked"
      AutomationId="add_email_button"
    />
  </VerticalStackLayout>
</ContentView>
