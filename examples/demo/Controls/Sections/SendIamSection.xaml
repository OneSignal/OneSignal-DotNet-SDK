<?xml version="1.0" encoding="utf-8" ?>
<ContentView
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:controls="clr-namespace:OneSignalDemo.Controls"
  x:Class="OneSignalDemo.Controls.Sections.SendIamSection"
>
  <VerticalStackLayout Spacing="8" AutomationId="send_iam_section">
    <controls:SectionHeader
      Title="SEND IN-APP MESSAGE"
      SectionKey="send_iam"
      InfoTapped="OnInfoTapped"
    />

    <Button
      Text="TOP BANNER"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnTopBannerTapped"
      AutomationId="send_iam_top_banner_button"
    />
    <Button
      Text="BOTTOM BANNER"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnBottomBannerTapped"
      AutomationId="send_iam_bottom_banner_button"
    />
    <Button
      Text="CENTER MODAL"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnCenterModalTapped"
      AutomationId="send_iam_center_modal_button"
    />
    <Button
      Text="FULL SCREEN"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnFullScreenTapped"
      AutomationId="send_iam_full_screen_button"
    />
  </VerticalStackLayout>
</ContentView>
