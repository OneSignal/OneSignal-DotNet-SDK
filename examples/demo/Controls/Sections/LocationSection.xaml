<?xml version="1.0" encoding="utf-8" ?>
<ContentView
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:controls="clr-namespace:OneSignalDemo.Controls"
  x:Class="OneSignalDemo.Controls.Sections.LocationSection"
>
  <VerticalStackLayout Spacing="8" AutomationId="location_section">
    <controls:SectionHeader Title="LOCATION" SectionKey="location" InfoTapped="OnInfoTapped" />

    <Border Style="{StaticResource CardBorderStyle}">
      <Grid Padding="12" ColumnDefinitions="*,Auto">
        <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
          <Label Text="Location Shared" Style="{StaticResource BodyMediumStyle}" />
          <Label
            Text="Share device location with OneSignal"
            Style="{StaticResource BodySmallStyle}"
          />
        </VerticalStackLayout>
        <Switch
          Grid.Column="1"
          x:Name="LocationSharedSwitch"
          IsToggled="False"
          Toggled="OnLocationSharedToggled"
          AutomationId="location_shared_toggle"
        />
      </Grid>
    </Border>

    <Button
      Text="PROMPT LOCATION"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnPromptLocationClicked"
      AutomationId="prompt_location_button"
    />
    <Button
      Text="CHECK LOCATION SHARED"
      Style="{StaticResource PrimaryButtonStyle}"
      Clicked="OnCheckLocationSharedClicked"
      AutomationId="check_location_button"
    />
  </VerticalStackLayout>
</ContentView>
