<?xml version="1.0" encoding="utf-8" ?>
<ContentView
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:services="clr-namespace:OneSignalDemo.Services"
  xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
  x:Class="OneSignalDemo.Controls.LogView"
  x:Name="root"
>
  <Grid AutomationId="log_view_container">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid
      Grid.Row="0"
      BackgroundColor="{StaticResource OsLogBackground}"
      Padding="16,12"
      AutomationId="log_view_header"
    >
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Grid.GestureRecognizers>
        <TapGestureRecognizer Tapped="OnHeaderTapped" />
      </Grid.GestureRecognizers>

      <Label
        Grid.Column="0"
        Text="LOGS"
        TextColor="White"
        FontAttributes="Bold"
        FontSize="11"
        VerticalOptions="Center"
      />
      <Label
        Grid.Column="1"
        x:Name="LogCountLabel"
        TextColor="{StaticResource OsGrey500}"
        FontSize="11"
        VerticalOptions="Center"
        Margin="8,0,0,0"
        AutomationId="log_view_count"
      />

      <mi:MauiIcon
        Grid.Column="3"
        x:Name="ClearIcon"
        Icon="{mi:Material Icon=Delete}"
        IconColor="{StaticResource OsGrey500}"
        IconSize="18"
        VerticalOptions="Center"
        Padding="8,0"
        IsVisible="False"
        AutomationId="log_view_clear_button"
      >
        <mi:MauiIcon.GestureRecognizers>
          <TapGestureRecognizer Tapped="OnClearClicked" />
        </mi:MauiIcon.GestureRecognizers>
      </mi:MauiIcon>

      <mi:MauiIcon
        Grid.Column="4"
        x:Name="CollapseArrow"
        Icon="{mi:Material Icon=ExpandLess}"
        IconColor="{StaticResource OsGrey500}"
        IconSize="18"
        VerticalOptions="Center"
        Padding="4,0,4,0"
      />
    </Grid>

    <!-- Log list -->
    <ScrollView
      Grid.Row="1"
      x:Name="LogScrollView"
      HeightRequest="100"
      Orientation="Both"
      BackgroundColor="{StaticResource OsLogBackground}"
      AutomationId="log_view_list"
    >
      <VerticalStackLayout x:Name="LogList" Spacing="0" Padding="12,0" />
    </ScrollView>
  </Grid>
</ContentView>
